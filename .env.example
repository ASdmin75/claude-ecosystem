# Claude Ecosystem — Environment Variables
# Copy this file to .env and fill in your values.
# Real environment variables take priority over .env values.

# --- Claude Auth ---
# Option 1: API key (pay-per-use)
# ANTHROPIC_API_KEY=sk-ant-...
#
# Option 2: Claude Code Max subscription (OAuth)
# Run `claude login` on host, then credentials are mounted from ~/.claude/.credentials.json
# Override path if needed:
# CLAUDE_CONFIG_DIR=~/.claude

# --- Authentication ---
# PASETO_KEY=hex-encoded-32-byte-key
# BEARER_TOKENS=token1,token2

# --- SMTP (for mcp-email and email notifications) ---
# Used both by the mcp-email MCP server and by task-level notify.email.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your@gmail.com

# --- Telegram (for mcp-telegram) ---
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHAT_ID=123456789

# --- Yeastar P-Series PBX (for daily-sip-processing pipeline) ---
# OAuth2 client credentials for Yeastar Open API.
# Create at PBX Admin → Integrations → API → Open API.
YEASTAR_BASE_URL=https://your-pbx.example.com
YEASTAR_CLIENT_ID=your-client-id
YEASTAR_CLIENT_PASSWORD=your-client-secret

# --- Server (optional overrides) ---
# SERVER_ADDR=:3580
# DATA_DIR=data

# --- Workspace (shared task I/O directory) ---
# WORKSPACE_DIR=./workspace
